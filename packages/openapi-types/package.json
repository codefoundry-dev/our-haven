{
  "name": "@our-haven/openapi-types",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript types generated from apps/backend/openapi/openapi.yaml. Source of truth per ADR-0004.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "openapi-typescript ../../apps/backend/openapi/openapi.yaml --output src/generated/schema.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  }
}
