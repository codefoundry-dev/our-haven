{
  "name": "our-haven",
  "private": true,
  "version": "0.0.0",
  "description": "Our Haven — two-sided childcare marketplace (monorepo: backend + mobile + provider-web + admin)",
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@our-haven/mobile",
    "mobile:ios": "npm run ios --workspace=@our-haven/mobile",
    "mobile:android": "npm run android --workspace=@our-haven/mobile",
    "mobile:web": "npm run web --workspace=@our-haven/mobile",
    "backend": "npm run dev --workspace=@our-haven/backend",
    "backend:test": "npm test --workspace=@our-haven/backend",
    "backend:build": "npm run build --workspace=@our-haven/backend",
    "openapi:generate": "npm run generate --workspace=@our-haven/openapi-types",
    "domain:test": "npm test --workspace=@our-haven/domain",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.11"
  }
}
