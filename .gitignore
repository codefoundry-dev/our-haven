# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo (apps/mobile)
.expo/
apps/mobile/dist/
apps/mobile/web-build/
apps/mobile/expo-env.d.ts
expo-env.d.ts

# TypeScript build artifacts
**/dist/
**/build/
*.tsbuildinfo

# Next.js build output (apps/admin, apps/provider-web)
.next/
out/
next-env.d.ts

# Backend env / secrets
apps/*/.env
apps/*/.env.*
!apps/*/.env.example
apps/backend/credentials/
apps/backend/.gcp/
**/*-credentials.json
**/service-account*.json

# Supabase Edge Functions env / secrets (ADR-0019)
supabase/functions/**/.env
supabase/functions/**/.env.*
!supabase/functions/**/.env.example
supabase/.temp/
supabase/.branches/

# Generated OpenAPI artifacts are committed (machine-generated source).
# CI runs `npm run openapi:generate` and fails on diff (see openapi:check).

# Local Docker volumes
**/.docker-data/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp
*.swo

# Generated native folders (Expo continuous prebuild)
/ios
/android
apps/mobile/ios
apps/mobile/android

# Misc
*.pem
example

# Claude design handoff bundle (extracted from anthropic design API for reference)
.design-bundle/

# Claude local state (project-level .claude)
.claude/scheduled_tasks.lock
