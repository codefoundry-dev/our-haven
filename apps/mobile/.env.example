# Our Haven — unified app (OH-176) env.
# Copy to `.env` and fill in. Only EXPO_PUBLIC_* vars are exposed to the client bundle.

# Supabase project (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base URL (Supabase Edge Functions host), e.g. https://<project-ref>.functions.supabase.co
# The role-claim call posts to ${EXPO_PUBLIC_API_URL}/v1/auth/role-claim
EXPO_PUBLIC_API_URL=
