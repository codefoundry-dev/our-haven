{
  "name": "@our-haven/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Our Haven backend — Node + TS + Fastify + OpenAPI + Postgres + Fly.io (ADR-0004 §§1-3,8 + ADR-0010 platform)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint not configured yet'",
    "openapi:emit": "tsx scripts/emit-openapi.ts",
    "openapi:check": "tsx scripts/check-openapi-drift.ts",
    "migrate:make": "tsx scripts/migrate.ts make",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@our-haven/domain": "*",
    "@our-haven/shared": "*",
    "@supabase/supabase-js": "^2.45.0",
    "fastify": "^5.5.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^5.9.0",
    "kysely": "^0.29.0",
    "pg": "^8.16.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0",
    "yaml": "^2.9.0"
  }
}
