# Our Haven backend env. Copy to .env (which is gitignored) for local dev.
# Source-of-truth schema lives in src/config/env.ts (Zod-validated at boot).
# Platform: Supabase + Fly.io per ADR-0010 (supersedes Firebase + GCP from ADR-0004).

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Postgres — local docker-compose maps to port 5432.
# In prod this points at the Supabase project's pooled connection string.
DATABASE_URL=postgres://our_haven:our_haven@localhost:5432/our_haven_dev
DATABASE_SSL=false

# Supabase — pull these from the Supabase Dashboard > Project Settings > API.
# In prod, set SUPABASE_URL to https://<project-ref>.supabase.co
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=uploads
SUPABASE_SIGNED_URL_TTL_SECONDS=300

# pgmq queues — installed by the enable_pgmq migration. Names only.
QUEUE_BOOKING=booking_lifecycle
QUEUE_RETENTION=retention_planner

# License-board adapter (OH-107). Comma-separated US-state codes for which a
# Specialist license-board adapter has shipped. Specialists outside this list
# route to verification holding-state-not-supported.
LICENSE_BOARD_SUPPORTED_STATES=

# Stripe (OH-106 + OH-110). Server-only — never ship to the client.
# STRIPE_WEBHOOK_SECRET is for the screening-charge webhook endpoint;
# STRIPE_CONNECT_WEBHOOK_SECRET is for the Connect Express account.updated
# webhook endpoint (separate Stripe webhook listener / secret).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/portal/verification?stripe=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/portal/verification?stripe=refresh
SCREENING_CHARGE_CENTS=3500

# Checkr (OH-106). Standard-package screening per ADR-0007.
# Webhook secret comes from the Checkr Dashboard > Webhooks.
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
CHECKR_PACKAGE=tasker_standard
CHECKR_API_BASE=https://api.checkr.com/v1
