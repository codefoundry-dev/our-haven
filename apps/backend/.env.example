# Our Haven backend env. Copy to .env (which is gitignored) for local dev.
# Source-of-truth schema lives in src/config/env.ts (Zod-validated at boot).

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# GCP — ADR-0004 §5 pins to us-east1 (fallback us-east4) + Firestore nam5.
GCP_PROJECT_ID=our-haven-local
GCP_REGION=us-east1
FIRESTORE_LOCATION=nam5

# Postgres — local docker-compose maps to port 5432.
DATABASE_URL=postgres://our_haven:our_haven@localhost:5432/our_haven_dev
DATABASE_SSL=false

# GCS uploads — bucket must exist and be in a US region.
GCS_UPLOAD_BUCKET=our-haven-uploads-dev
GCS_SIGNED_URL_TTL_SECONDS=300

# Cloud Tasks — queues live in the same region; only names here.
CLOUD_TASKS_QUEUE_BOOKING=booking-lifecycle
CLOUD_TASKS_QUEUE_RETENTION=retention-planner

# Firebase Admin — leave unset in Cloud Run (uses workload identity / ADC).
# For local dev pointing at a real Firebase project, set to your service-account JSON path.
# FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/our-haven-firebase-adminsdk.json

# Local Firestore emulator (only set when using docker-compose firestore-emulator):
# FIRESTORE_EMULATOR_HOST=localhost:8085
