# worker-tick Edge Function env (ADR-0019 § Decision 4; OH-237).
# Source-of-truth schema: config/env.ts (Zod-validated at boot).
# Set deployed values with `supabase secrets set --env-file …` (NOT committed).

# Postgres — Supavisor TRANSACTION pooler (:6543). postgres.js, prepare:false.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Shared secret the pg_cron + pg_net minute tick presents as
# `Authorization: Bearer <secret>`. Must equal the `app.worker_tick_secret`
# DB GUC the cron command reads (see README.md). Generate a long random value.
WORKER_TICK_SECRET=
