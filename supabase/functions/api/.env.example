# Environment for the `api` fat Edge Function (ADR-0019).
#
# Deploy secrets:  supabase secrets set --env-file supabase/functions/api/.env
# Local serve:     supabase functions serve api --no-verify-jwt --env-file supabase/functions/api/.env
#
# DATABASE_URL must point at the SUPAVISOR TRANSACTION pooler (:6543) — the
# connection mode Edge Functions use (ADR-0019 § Decision 3). postgres.js
# connects with prepare:false through it. Note the dotted username + :6543; the
# region shard (aws-0/aws-1/…) is project-specific — copy from the dashboard.
DATABASE_URL=postgresql://postgres.rtamfcbkrtztxbbkvwpz:<db-password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Supabase project JWT secret (HS256). Dashboard → Project Settings → API → JWT Secret.
# The auth middleware verifies access tokens locally with this — no network call.
# NOTE: named JWT_SECRET, not SUPABASE_JWT_SECRET — Supabase reserves the
# SUPABASE_ prefix for its own auto-injected vars, so a SUPABASE_*-prefixed
# secret cannot be set via `supabase secrets set`.
JWT_SECRET=<your-project-jwt-secret>
